{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/lbs-delivery/mandant.schema.json",
  "title": "Mandant configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mandant"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "mandant": {
      "$ref": "#/$defs/mandant"
    }
  },
  "$defs": {
    "mandant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "repository",
        "subsystem",
        "projects",
        "handover_profiles"
      ],
      "properties": {
        "code": {
          "enum": [
            "FI",
            "BY",
            "LH",
            "NW",
            "OS",
            "SA",
            "IT"
          ]
        },
        "repository": {
          "type": "string",
          "pattern": "^mtext-(?:[a-z]{2}|autonom)$"
        },
        "subsystem": {
          "description": "Mandantenspezifisches Subsystem für die JCL-Übergabe.",
          "type": "string",
          "pattern": "^[A-Z0-9]{2,8}$"
        },
        "projects": {
          "description": "Allowlist der durch Synchronisation und Release verarbeiteten Projekte; weitere Repositoryinhalte bleiben unberücksichtigt.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/project"
          }
        },
        "handover_profiles": {
          "description": "Mandantenspezifische Assignment- und Stage-Zuordnungen für die zentral je Releaselinie ausgewählten Übergabeprofile.",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "FKT",
            "JUR"
          ],
          "properties": {
            "FKT": {
              "$ref": "#/$defs/handover_profile"
            },
            "JUR": {
              "$ref": "#/$defs/handover_profile"
            }
          }
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source_path"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9_\\[\\]-]+$"
        },
        "source_path": {
          "$ref": "#/$defs/relative_path"
        }
      }
    },
    "handover_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assignment",
        "stage"
      ],
      "properties": {
        "assignment": {
          "description": "Mandantenspezifisches Assignment, das unverändert in den historischen JCL-Platzhalter ASSIGNMENT eingesetzt wird.",
          "type": "string",
          "pattern": "^[A-Z0-9]{1,12}$"
        },
        "stage": {
          "description": "Fachlicher Stage-Code, der unverändert in den historischen JCL-Platzhalter LEVEL eingesetzt wird.",
          "enum": [
            "FKTE",
            "FKTF",
            "JURJ",
            "JURP",
            "SVTS",
            "VPTV"
          ]
        }
      }
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000]+$"
    }
  }
}
