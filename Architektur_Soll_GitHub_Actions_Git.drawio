        </mxCell>
        <mxCell id="artifact" value="Artefakt desselben Laufs&#xa;&lt;Kürzel&gt;&lt;Liefercode&gt;&lt;F|D&gt;.tgz&#xa;FULL oder kumulatives DELTA&#xa;+ Information + manifest.json&#xa;Tag, Ziel-SHA, Größe, SHA-256&#xa;ARTIFACT_READY" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1080" y="975" width="200" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="approval" value="Environment Bereitstellung&#xa;manuelle Freigabe der&#xa;Mainframe-Übergabe&#xa;Secrets erst danach" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="1">
