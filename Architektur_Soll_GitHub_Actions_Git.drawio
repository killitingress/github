        </mxCell>
        <mxCell id="build-job" value="Job build&#xa;kein Zugriff auf Zielsystem-Secrets&#xa;Tag / Branch / Mandant / Releaselinie prüfen&#xa;FULL bei .100, sonst DELTA&#xa;.100 muss Vorgänger sein&#xa;build-release" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="1">
